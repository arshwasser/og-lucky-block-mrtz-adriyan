local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Ladebildschirm
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "LoadingScreen"
screenGui.Parent = playerGui

-- Schwarzer Hintergrund
local background = Instance.new("Frame")
background.Parent = screenGui
background.Size = UDim2.new(1, 0, 1, 0)
background.BackgroundColor3 = Color3.fromRGB(0, 0, 0)

-- Text
local loadingText = Instance.new("TextLabel")
loadingText.Parent = background
loadingText.Size = UDim2.new(1, 0, 1, 0)
loadingText.BackgroundTransparency = 1
loadingText.Text = "FREE SAB SCRIPTS | discord.gg/vV4TBnjxds"
loadingText.TextScaled = true
loadingText.TextColor3 = Color3.fromRGB(255, 221, 85)
loadingText.Font = Enum.Font.GothamBold

task.wait(3)
screenGui:Destroy()

-- Notification sicher
local function notify(text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "FREE SAB SCRIPTS",
            Text = text,
            Duration = 5
        })
    end)
end

-- Text ändern (NUR Lucky Block)
local function changeText(v)
    if not v:IsA("TextLabel") then return end

    if v.Text == "Lucky Block" then
        v.Text = "OG Lucky Block"
        v.TextColor3 = Color3.fromRGB(255,221,85)

        if not v:FindFirstChildOfClass("UIStroke") then
            local stroke = Instance.new("UIStroke")
            stroke.Color = Color3.fromRGB(0,0,0)
            stroke.Thickness = 2
            stroke.Parent = v
        end

        if not v:FindFirstChildOfClass("UIGradient") then
            local gradient = Instance.new("UIGradient")
            gradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,221,85)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))
            }
            gradient.Rotation = 90
            gradient.Parent = v
        end
    end
end

-- Bestehende UI
for _, v in pairs(game:GetDescendants()) do
    changeText(v)
end

-- Neue UI
game.DescendantAdded:Connect(changeText)

notify("Script loaded!")
